{
	"name": "luiz-dk-sveltekit",
	"private": true,
	"version": "1.5.2",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
		"prepare": "bun run types && svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run",
		"types": "wrangler types",
		"deploy": "CF_PAGES=1 bun run build && CF_PAGES=1 wrangler pages deploy",
		"tail:pages": "wrangler pages deployment tail --project-name luiz-dk-sveltekit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:prod": "drizzle-kit migrate --config=drizzle.prod.config.ts",
		"db:push": "drizzle-kit push",
		"clear": "rm -rf node_modules/ .svelte-kit/ .wrangler/ dist/ coverage/ pnpm-lock.yaml bun.lockb bun.lock package-lock.json yarn.lock"
	},
	"lint-staged": {
		"*.{js,ts,svelte,json}": [
			"prettier --write",
			"eslint"
		]
	},
	"devDependencies": {
		"@clerk/backend": "^3.4.1",
		"@clerk/themes": "^2.4.57",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@sentry/sveltekit": "^10.50.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^4.1.5",
		"better-sqlite3": "^12.9.0",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"hashids": "^2.3.0",
		"husky": "^9.1.7",
		"ioredis": "^5.10.1",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"semantic-release": "^25.0.3",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"svix": "^1.92.2",
		"tailwindcss": "^4.2.4",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"wrangler": "^4.85.0",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@tanstack/svelte-table": "9.0.0-alpha.10",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"layercake": "^10.0.2"
	}
}
